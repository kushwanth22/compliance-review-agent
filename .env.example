# ─────────────────────────────────────────────
# Compliance Review Agent — Environment Config
# Copy to .env and fill in values
# ─────────────────────────────────────────────

# Environment: local | poc | prod
ENV=local

# ── LLM (LiteLLM unified interface) ──────────
# POC 0 (zero cost): Ollama running locally
LLM_PROVIDER=ollama
LLM_MODEL=ollama/llama3
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# POC 1 (Azure - swap these, no code changes):
# LLM_PROVIDER=azure
# LLM_MODEL=azure/gpt-4o-mini
# AZURE_API_KEY=your-azure-openai-key
# AZURE_API_BASE=https://your-instance.openai.azure.com/
# AZURE_API_VERSION=2024-02-01

# ── Embeddings ───────────────────────────────
# POC 0: Ollama local embeddings
EMBEDDING_MODEL=ollama/nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434

# POC 1: Azure OpenAI embeddings
# EMBEDDING_MODEL=azure/text-embedding-3-small

# ── Vector Store ─────────────────────────────
# POC 0: ChromaDB (local file-based, zero cost)
VECTOR_STORE=chroma
CHROMA_PATH=./data/chroma_db
CHROMA_COLLECTION_COMPLIANCE=compliance_docs

# POC 1: Azure AI Search (free tier)
# VECTOR_STORE=azure_search
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_KEY=your-search-key
# AZURE_SEARCH_INDEX=compliance-docs

# ── Database ─────────────────────────────────
# POC 0: SQLite (zero cost)
DATABASE_URL=sqlite+aiosqlite:///./data/compliance.db

# POC 1: Azure PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/compliance

# ── Redis (optional async job queue) ─────────
REDIS_URL=redis://localhost:6379/0

# ── API ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_SECRET_KEY=change-me-in-production-use-secrets-manager

# ── Compliance Review Settings ───────────────
# Domains to run (comma separated)
REVIEW_DOMAINS=brand,legal,accessibility,global_readiness,product_marketing

# Severity threshold to trigger human escalation (high | medium | low)
ESCALATION_THRESHOLD=high

# Max tokens per RAG chunk
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
